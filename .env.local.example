# ── Supabase ──────────────────────────────────────────────
# Project URL（公開，可放前端）
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon Key（公開，限 RLS 保護的讀取操作）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key（私密，僅 server-side 使用，絕不放前端）
# 來源：Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Gemini ──────────────────────────────────────────
# 來源：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
